# ============================================================
# WhatsApp Fatawa Bot — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env or firebase-service-account.json to version control
# ============================================================

# --- OpenAI ---
# Used for: Whisper transcription, text-embedding-3-small, TTS
OPENAI_API_KEY=sk-...

# --- Google Gemini ---
# Used for: categorization, answer drafting
GEMINI_API_KEY=AIza...

# --- Firebase ---
# Your Firebase project ID (the string ID, NOT the number)
# Find it: Firebase Console → Project Settings → General → Project ID
# For project number 482087882369, the ID is shown just above the number
FIREBASE_PROJECT_ID=your-project-id

# Path to your downloaded service account JSON key file
# How to get it:
#   1. Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate new private key" → Download JSON
#   3. Place it in the WABOT folder, name it firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- WhatsApp Group JIDs ---
# Leave blank on first run — the bot will boot and show QR.
# After scanning, post a message in each group and check logs for the JIDs.
# Format: <phone_number_with_country_code>-<timestamp>@g.us
ADMIN_GROUP_JID=
PUBLIC_GROUP_JID=

# --- TTS Settings ---
# Options: openai | elevenlabs
TTS_PROVIDER=openai
# OpenAI TTS voice: alloy | echo | fable | onyx | nova | shimmer
OPENAI_TTS_VOICE=nova
# ElevenLabs (optional — only needed if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- Pipeline Settings ---
DEDUP_SIMILARITY_THRESHOLD=0.92
MATCH_THRESHOLD=0.55
MATCH_COUNT=5

# --- Logging ---
LOG_LEVEL=info

# --- Auth & Temp ---
AUTH_DIR=./auth_info_baileys
TMP_DIR=./tmp
