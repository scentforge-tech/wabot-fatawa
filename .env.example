# ============================================================
# WhatsApp Fatawa Bot — Environment Configuration
# Only 2 API keys required! Everything runs on Google/Firebase.
# ============================================================

# --- Google Gemini ---
# Used for: audio transcription, text embeddings, categorization, answer drafting
# Get it: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# --- Firebase / Google Cloud ---
# Your Firebase project ID (text string, not the number 482087882369)
# Find it: https://console.firebase.google.com/project/482087882369/settings/general
FIREBASE_PROJECT_ID=your-project-id

# Path to downloaded service account JSON key
# How to get it:
#   Firebase Console → Project Settings → Service Accounts
#   → "Generate new private key" → download → rename → place in WABOT/
# This key also authenticates: Firestore, Google Cloud TTS (no extra key needed!)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- WhatsApp Groups ---
# Leave blank on first run. Scan QR, then check logs for JIDs.
ADMIN_GROUP_JID=
PUBLIC_GROUP_JID=

# --- TTS Language (auto-detect by default) ---
# auto = detect Urdu vs English from text
# ur-PK = always use Urdu voice (ur-PK-Wavenet-A)
# en-US = always use English voice (en-US-Neural2-D)
TTS_LANGUAGE_OVERRIDE=auto

# --- Pipeline Settings ---
DEDUP_SIMILARITY_THRESHOLD=0.92
MATCH_THRESHOLD=0.55
MATCH_COUNT=5

# --- Logging ---
LOG_LEVEL=info

# --- Auth & Temp ---
AUTH_DIR=./auth_info_baileys
TMP_DIR=./tmp

# --- Cloud Run (set automatically by Cloud Run, don't change) ---
PORT=8080
