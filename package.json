    "firebase-admin": "^13.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "glob": "^11.0.0",
    "openai": "^4.67.0",
    "p-limit": "^6.1.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.7.5",
    "@types/qrcode-terminal": "^0.12.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
